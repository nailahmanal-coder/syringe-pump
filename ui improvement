void moveMotor(int dirPin, int stepPin, int steps) {
  if (steps >= 0) {
    digitalWrite(dirPin, LOW);
  } else {
    digitalWrite(dirPin, HIGH);
    steps = -steps;
  }
  for (int i = 0; i < steps; i++) {
    digitalWrite(stepPin, HIGH);
    delayMicroseconds(800);
    digitalWrite(stepPin, LOW);
    delayMicroseconds(800);
  }
}

void handleRoot() {
  server.send(200, "text/html", htmlPage);
}

void handleMove() {
  int motor = server.arg("motor").toInt();
  int steps = server.arg("steps").toInt();
  int dir = server.arg("dir").toInt();
  steps = steps * dir;
  if (motor == 1) {
    moveMotor(dirPin1, stepPin1, steps);
    server.send(200, "text/plain", "Syringe 1 moved " + String(steps) + " steps");
  } else if (motor == 2) {
    moveMotor(dirPin2, stepPin2, steps);
    server.send(200, "text/plain", "Syringe 2 moved " + String(steps) + " steps");
  } else {
    server.send(400, "text/plain", "Invalid motor selection");
  }
}

void setup() {
  Serial.begin(115200);
  pinMode(dirPin1, OUTPUT); pinMode(stepPin1, OUTPUT);
  pinMode(dirPin2, OUTPUT); pinMode(stepPin2, OUTPUT);
  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) { delay(500); Serial.print("."); }
  Serial.println("\nConnected!");
  Serial.println(WiFi.localIP());
  server.on("/", handleRoot);
  server.on("/move", handleMove);
  server.begin();
}

void loop() {
  server.handleClient();
}

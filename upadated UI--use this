unsigned long calculateStepIntervalUs(float flowRateMlMin) {
  if (flowRateMlMin <= 0) {
    return 1000000UL;
  }

  float stepsPerSecond = (flowRateMlMin * stepsPerMl) / 60.0;
  if (stepsPerSecond <= 0) {
    return 1000000UL;
  }

  unsigned long interval = (unsigned long)(1000000.0 / stepsPerSecond);
  if (interval < (minPulseWidthUs * 2UL)) {
    interval = minPulseWidthUs * 2UL;
  }
  return interval;
}

void pulseStep(int stepPin) {
  digitalWrite(stepPin, HIGH);
  delayMicroseconds(minPulseWidthUs);
  digitalWrite(stepPin, LOW);
}

void moveMotor(int dirPin, int stepPin, int steps, float flowRateMlMin) {
  if (steps >= 0) {
    digitalWrite(dirPin, LOW);
  } else {
    digitalWrite(dirPin, HIGH);
    steps = -steps;
  }

  unsigned long stepIntervalUs = calculateStepIntervalUs(flowRateMlMin);

  for (int i = 0; i < steps; i++) {
    pulseStep(stepPin);
    if (stepIntervalUs > minPulseWidthUs) {
      delayMicroseconds(stepIntervalUs - minPulseWidthUs);
    }
  }
}

void moveDualMotors(int steps1, int steps2, float flowRate1, float flowRate2) {
  if (steps1 >= 0) {
    digitalWrite(dirPin1, LOW);
  } else {
    digitalWrite(dirPin1, HIGH);
    steps1 = -steps1;
  }

  if (steps2 >= 0) {
    digitalWrite(dirPin2, LOW);
  } else {
    digitalWrite(dirPin2, HIGH);
    steps2 = -steps2;
  }

  unsigned long interval1 = calculateStepIntervalUs(flowRate1);
  unsigned long interval2 = calculateStepIntervalUs(flowRate2);
  unsigned long nextStep1 = micros();
  unsigned long nextStep2 = micros();
  int done1 = 0;
  int done2 = 0;

  while (done1 < steps1 || done2 < steps2) {
    unsigned long now = micros();
    bool moved = false;

    if (done1 < steps1 && (long)(now - nextStep1) >= 0) {
      pulseStep(stepPin1);
      nextStep1 += interval1;
      done1++;
      moved = true;
    }

    if (done2 < steps2 && (long)(now - nextStep2) >= 0) {
      pulseStep(stepPin2);
      nextStep2 += interval2;
      done2++;
      moved = true;
    }

    if (!moved) {
      delayMicroseconds(50);
    }
  }
}

bool validateVolumeChange(float remainingVolume, float volume, int dir, String& errorMessage) {
  if (volume <= 0 || volume > syringeVolumeMl) {
    errorMessage = "Enter a volume between 0.1 and 20.0 mL.";
    return false;
  }

  if (dir == 1 && volume > remainingVolume) {
    errorMessage = "Requested infuse volume is greater than remaining fluid.";
    return false;
  }

  if (dir == -1 && remainingVolume + volume > syringeVolumeMl) {
    errorMessage = "Withdraw volume exceeds syringe refill capacity.";
    return false;
  }

  return true;
}

void applyVolumeChange(float& remainingVolume, float volume, int dir) {
  if (dir == 1) {
    remainingVolume -= volume;
  } else {
    remainingVolume += volume;
  }
}


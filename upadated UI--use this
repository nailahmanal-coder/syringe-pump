String escapeJson(const String& input) {
  String output = "";
  for (unsigned int i = 0; i < input.length(); i++) {
    char c = input[i];
    if (c == '\\' || c == '"') {
      output += '\\';
    }
    output += c;
  }
  return output;
}

String makeJsonResponse(const String& message, const String& alarm) {
  String json = "{";
  json += "\"message\":\"" + escapeJson(message) + "\",";
  json += "\"state\":\"" + escapeJson(pumpState) + "\",";
  json += "\"remaining1\":" + String(remainingVolume1, 2) + ",";
  json += "\"remaining2\":" + String(remainingVolume2, 2) + ",";
  json += "\"alarm\":\"" + escapeJson(alarm) + "\"";
  json += "}";
  return json;
}


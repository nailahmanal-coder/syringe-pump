void handleMove() {
  int motor = server.arg("motor").toInt();
  float volume = server.arg("volume").toFloat();
  float flowRate = server.arg("flowRate").toFloat();
  int dir = server.arg("dir").toInt();
  int steps = (int)(volume * stepsPerMl + 0.5f) * dir;
  String errorMessage = "";

  if (flowRate <= 0) {
    server.send(400, "application/json", makeJsonResponse("Flow rate must be greater than 0 mL/min.", "Flow rate out of range"));
    return;
  }

  if (motor == 1) {
    if (!validateVolumeChange(remainingVolume1, volume, dir, errorMessage)) {
      server.send(400, "application/json", makeJsonResponse(errorMessage, "Barrel A command blocked"));
      return;
    }

    pumpState = "Running Barrel A";
    moveMotor(dirPin1, stepPin1, steps, flowRate);
    applyVolumeChange(remainingVolume1, volume, dir);
    pumpState = "Idle";
    lastAction = "Barrel A ";
    lastAction += (dir == 1 ? "infused " : "withdrew ");
    lastAction += String(volume, 2) + " mL at " + String(flowRate, 2) + " mL/min (" + String(abs(steps)) + " steps)";
    server.send(200, "application/json", makeJsonResponse(lastAction, ""));
    return;
  }

  if (motor == 2) {
    if (!validateVolumeChange(remainingVolume2, volume, dir, errorMessage)) {
      server.send(400, "application/json", makeJsonResponse(errorMessage, "Barrel B command blocked"));
      return;
    }

    pumpState = "Running Barrel B";
    moveMotor(dirPin2, stepPin2, steps, flowRate);
    applyVolumeChange(remainingVolume2, volume, dir);
    pumpState = "Idle";
    lastAction = "Barrel B ";
    lastAction += (dir == 1 ? "infused " : "withdrew ");
    lastAction += String(volume, 2) + " mL at " + String(flowRate, 2) + " mL/min (" + String(abs(steps)) + " steps)";
    server.send(200, "application/json", makeJsonResponse(lastAction, ""));
    return;
  }

  server.send(400, "application/json", makeJsonResponse("Invalid barrel selection.", "Invalid motor"));
}

void handleMoveBoth() {
  String mode = server.arg("mode");
  float volume1 = server.arg("volume1").toFloat();
  float flow1 = server.arg("flow1").toFloat();
  int dir1 = server.arg("dir1").toInt();
  float volume2 = server.arg("volume2").toFloat();
  float flow2 = server.arg("flow2").toFloat();
  int dir2 = server.arg("dir2").toInt();
  String errorMessage = "";

  if (flow1 <= 0 || flow2 <= 0) {
    server.send(400, "application/json", makeJsonResponse("Both flow rates must be greater than 0 mL/min.", "Flow rate out of range"));
    return;
  }

  if (!validateVolumeChange(remainingVolume1, volume1, dir1, errorMessage)) {
    server.send(400, "application/json", makeJsonResponse(errorMessage, "Barrel A command blocked"));
    return;
  }

  if (!validateVolumeChange(remainingVolume2, volume2, dir2, errorMessage)) {
    server.send(400, "application/json", makeJsonResponse(errorMessage, "Barrel B command blocked"));
    return;
  }

  int steps1 = (int)(volume1 * stepsPerMl + 0.5f) * dir1;
  int steps2 = (int)(volume2 * stepsPerMl + 0.5f) * dir2;
  pumpState = (mode == "sync") ? "Running Both (Sync)" : "Running Both";

  if (mode == "sync") {
    moveDualMotors(steps1, steps2, flow1, flow2);
  } else {
    moveMotor(dirPin1, stepPin1, steps1, flow1);
    moveMotor(dirPin2, stepPin2, steps2, flow2);
  }

  applyVolumeChange(remainingVolume1, volume1, dir1);
  applyVolumeChange(remainingVolume2, volume2, dir2);
  pumpState = "Idle";

  lastAction = "Barrel A ";
  lastAction += (dir1 == 1 ? "infused " : "withdrew ");
  lastAction += String(volume1, 2);
  lastAction += " mL and Barrel B ";
  lastAction += (dir2 == 1 ? "infused " : "withdrew ");
  lastAction += String(volume2, 2);
  lastAction += " mL using ";
  lastAction += (mode == "sync") ? "synchronized" : "independent";
  lastAction += " mode.";

  server.send(200, "application/json", makeJsonResponse(lastAction, ""));
}

void setup() {
  Serial.begin(115200);

  pinMode(dirPin1, OUTPUT);
  pinMode(stepPin1, OUTPUT);
  pinMode(dirPin2, OUTPUT);
  pinMode(stepPin2, OUTPUT);

  WiFi.begin(ssid, password);
  Serial.print("Connecting");

  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }

  Serial.println();
  Serial.println("Connected");
  Serial.println(WiFi.localIP());

  server.on("/", handleRoot);
  server.on("/status", handleStatus);
  server.on("/move", handleMove);
  server.on("/moveBoth", handleMoveBoth);

  server.begin();
}

void loop() {
  server.handleClient();
}
